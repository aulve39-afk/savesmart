# ── NextAuth ──────────────────────────────────────────────────
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET=GENERER_AVEC_openssl_rand_-base64_32
NEXTAUTH_URL=https://savesmart-alpha.vercel.app

# ── Google OAuth (Gmail scan) ─────────────────────────────────
# Créer sur : https://console.cloud.google.com/apis/credentials
# Scopes requis : openid email profile gmail.readonly
GOOGLE_CLIENT_ID=votre-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── IA ────────────────────────────────────────────────────────
# OpenAI : https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...
# Anthropic (optionnel, fallback) : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Resend (emails transactionnels) ───────────────────────────
# Créer sur : https://resend.com/api-keys (3 000 emails/mois gratuits)
RESEND_API_KEY=re_...
# Email qui reçoit les notifications leads
NOTIFY_EMAIL=toi@entreprise.fr

# ── Edge Function Webhook (interne Supabase) ──────────────────
# Déjà configuré — ne pas changer sauf si compromis
WEBHOOK_SECRET=wh-savesmart-leads-2026

# ── Backend FastAPI (optionnel en local) ──────────────────────
