# ── Copier ce fichier en .env et remplir les valeurs ─────────────────────────
# cp .env.example .env

# ── OpenAI (phase dev — remplacer par Anthropic en prod) ─────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Supabase (PostgreSQL + Auth + RLS RGPD) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# ── AWS S3 (région EU obligatoire pour RGPD) ──────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=audit-agent-contracts-eu
S3_REGION=eu-central-1

# ── Redis (broker Celery + backend résultats) ─────────────────────────────────
# Redis Cloud gratuit: https://redis.com/try-free/
# Format: redis://default:<password>@<host>:<port>
REDIS_URL=redis://default:password@redis-host:port

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Générer avec: openssl rand -hex 32
SECRET_KEY=CHANGE-ME-IN-PRODUCTION-USE-openssl-rand-hex-32
